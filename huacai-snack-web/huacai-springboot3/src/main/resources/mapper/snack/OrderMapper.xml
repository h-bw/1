<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.huacai.snack.mapper.OrderMapper">

    <resultMap type="Order" id="OrderResult">
        <result property="orderId"    column="order_id"    />
        <result property="name"    column="name"    />
        <result property="phone"    column="phone"    />
        <result property="address"    column="address"    />
        <result property="totalAmount"    column="total_amount"    />
        <result property="productCount"    column="product_count"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="userId"    column="user_id"    />
        <result property="createTime"    column="create_time"    />
        <result property="userName"    column="user_name"    />
    </resultMap>

    <resultMap id="OrderOrderProductsResult" type="Order" extends="OrderResult">
        <collection property="orderProductsList" ofType="OrderProducts" column="order_id" select="selectOrderProductsList" />
    </resultMap>

    <resultMap type="OrderProducts" id="OrderProductsResult">
        <result property="opId"    column="op_id"    />
        <result property="orderId"    column="order_id"    />
        <result property="image"    column="image"    />
        <result property="name"    column="name"    />
        <result property="price"    column="price"    />
        <result property="quantity"    column="quantity"    />
    </resultMap>

    <sql id="selectOrderVo">
        select order_id, name, phone, address, total_amount, product_count, status, remark, user_id, create_time from `order`
    </sql>

    <select id="selectOrderList" parameterType="Order" resultMap="OrderOrderProductsResult">
        select o.order_id, o.name, o.phone, o.address, o.total_amount, o.product_count, o.status,
               o.remark, o.user_id, o.create_time,
               u.user_name
        from `order` o
        left join sys_user u on o.user_id = u.user_id
        <where>
            <if test="orderId != null  and orderId != ''"> and o.order_id = #{orderId}</if>
            <if test="status != null  and status != ''"> and o.status = #{status}</if>
            <if test="userId != null "> and o.user_id = #{userId}</if>
            <if test="userName != null  and userName != ''"> and u.user_name like concat('%', #{userName}, '%')</if>
        </where>
        order by o.create_time desc
    </select>

    <select id="selectOrderByOrderId" parameterType="String" resultMap="OrderOrderProductsResult">
        select order_id, name, phone, address, total_amount, product_count, status, remark, user_id, create_time
        from `order`
        where order_id = #{orderId}
    </select>

    <select id="selectOrderProductsList" resultMap="OrderProductsResult">
        select op_id, order_id, image, name, price, quantity
        from order_products
        where order_id = #{order_id}
    </select>

    <!--查询每种状态在订单中各有多少个-->
    <select id="selectOrderStatus" resultType="com.huacai.snack.domain.vo.OrderStatusBarVO">
        select status as orderStatus, count(order_id) as orderCount
        from `order`
        group by status
    </select>

    <insert id="insertOrder" parameterType="Order">
        insert into `order`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderId != null">order_id,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="phone != null and phone != ''">phone,</if>
            <if test="address != null and address != ''">address,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="productCount != null">product_count,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null">remark,</if>
            <if test="userId != null">user_id,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderId != null">#{orderId},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="phone != null and phone != ''">#{phone},</if>
            <if test="address != null and address != ''">#{address},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="productCount != null">#{productCount},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="userId != null">#{userId},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateOrder" parameterType="Order">
        update `order`
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="address != null and address != ''">address = #{address},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="productCount != null">product_count = #{productCount},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where order_id = #{orderId}
    </update>

    <delete id="deleteOrderByOrderId" parameterType="String">
        delete from `order` where order_id = #{orderId}
    </delete>

    <delete id="deleteOrderByOrderIds" parameterType="String">
        delete from `order` where order_id in
        <foreach item="orderId" collection="array" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </delete>

    <delete id="deleteOrderProductsByOrderIds" parameterType="String">
        delete from order_products where order_id in
        <foreach item="orderId" collection="array" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </delete>

    <delete id="deleteOrderProductsByOrderId" parameterType="String">
        delete from order_products where order_id = #{orderId}
    </delete>

    <insert id="batchOrderProducts">
        insert into order_products( op_id, order_id, image, name, price, quantity) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.opId}, #{item.orderId}, #{item.image}, #{item.name}, #{item.price}, #{item.quantity})
        </foreach>
    </insert>
</mapper>
